{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/exdragine/frontier-model-catalog/catalog.schema.json",
  "title": "Frontier Model Catalog Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_version", "updated_at", "providers"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+$"},
    "catalog_version": {"type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$"},
    "updated_at": {"type": "string", "format": "date"},
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "file"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "file": {"type": "string", "pattern": "^providers/[a-z][a-z0-9_-]*\\.json$"}
        }
      }
    }
  }
}
