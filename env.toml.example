config_version = 2

# 主 system prompt。名称来自 .env 的 NICKNAME；群聊数据库中的自定义
# 唤醒词会覆盖对应群的全局名称。
[bot]
system_prompt = """
你是 {name}，一个友好的 QQ 聊天机器人。

对话原则：
- 用简洁的中文回复，像真人聊天一样自然。短消息优先，不要长篇大论。
- 简单的问候、闲聊直接文字回复，不要调用工具。
- 只有真正需要查资料、搜索、画图等才用工具。
- 能帮忙就帮，帮不了就直说。
"""

# 模型角色。advanced_* 对应主 Agent，basic_* 用于轻量辅助任务，
# signal_* 用于结构化意图判断。
[models]
basic_model = ""
basic_model_provider = "openai" # 指向 [providers.<name>]
basic_model_capabilities = ["text"] # 可选: "text", "vision"；"image" 与 "vision" 等价

signal_model = "deepseek-v4-flash"
signal_model_provider = "deepseek"
signal_model_capabilities = ["text"]

advanced_model = ""
advanced_model_provider = "openai"
advanced_model_capabilities = ["text"]

paint_model = "gpt-image-2"
paint_model_provider = "openai"
paint_size = "1024x1024"
paint_quality = "auto" # "low", "medium", "high", "auto"
video_model = "sora-2"
video_model_provider = "openai"
video_size = "1280x720"
video_seconds = "8"

# 供应商 profile 统一管理协议类型、地址和 API 模式。
# type 决定底层 SDK；模型的 *_model_provider 填写这里的 profile 名称。
[providers.openai]
type = "openai"
base_url = ""
api_key = ""
use_responses_api = true

[providers.google]
type = "google"
base_url = ""
api_key = ""
use_responses_api = false

[providers.anthropic]
type = "anthropic"
base_url = ""
api_key = ""
use_responses_api = false

[providers.deepseek]
type = "deepseek"
base_url = ""
api_key = ""
use_responses_api = false

# OpenAI-compatible 代理示例。
[providers.openrouter]
type = "openai"
base_url = ""
api_key = ""
use_responses_api = true

# 非模型服务密钥。
[key]
nasa_api_key = "DEMO_KEY"
github_pat = ""

[features]
agent_enabled = true
paint_enabled = true
video_enabled = true

[agent]
reasoning_effort = "medium" # "low", "medium", "high", "xhigh"

[agent_policy]
whitelist_mode = false
whitelist_person_list = []
whitelist_group_list = []
blacklist_person_list = []
blacklist_group_list = []

[auto_reply_policy]
whitelist_mode = false
whitelist_group_list = []
blacklist_group_list = []

[paint_policy]
whitelist_mode = false
whitelist_person_list = []
whitelist_group_list = []
blacklist_person_list = []
blacklist_group_list = []

[limits]
paint_rate_limit_max_requests = 3
paint_rate_limit_window_seconds = 600
video_rate_limit_max_requests = 1
video_rate_limit_window_seconds = 900
video_poll_interval_seconds = 15
video_poll_timeout_seconds = 900
agent_llm_timeout_seconds = 900
agent_job_timeout_seconds = 3600

[notifications]
test_group_id = []
announce_group_id = []
apod_group_id = []
earth_now_group_id = []
news_summary_group_id = []
earthquake_group_id = []
nrc_merchant_group_id = []

[storage]
query_message_numbers = 100
image_enabled = true
image_ttl_days = 30
image_auto_cleanup = true

[debug]
agent_debug_mode = false

[dashboard]
password = "admin"
jwt_secret = "change-this-to-a-random-string-in-production"
jwt_expire_hours = 24

[content_check]
# 需要先执行 `uv sync --extra content-check`；Docker 使用 runtime-content-check 构建目标。
enabled = false
