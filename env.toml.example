[information]
name = ""
system_prompt= """
你是 {name}，一个友好的 QQ 聊天机器人。

对话原则：
- 用简洁的中文回复，像真人聊天一样自然。短消息优先，不要长篇大论。
- 简单的问候、闲聊直接文字回复，不要调用工具。
- 只有真正需要查资料、搜索、画图等才用工具。
- 能帮忙就帮，帮不了就直说。
"""

[endpoint]
openai_base_url = ""
basic_model = ""
basic_model_provider = "" # 可选: "openai", "google", "anthropic"
basic_model_endpoint = "" # 可选: 指向 [llm_endpoints.<name>]
basic_model_capabilities = ["text"] # 可选: "text", "vision"
signal_model = "deepseek-v4-flash"
signal_model_provider = "deepseek" # 可选: "openai", "google", "anthropic", "deepseek"
signal_model_endpoint = "" # 可选: 指向 [llm_endpoints.<name>]
signal_model_capabilities = ["text"]
advan_model = ""
advan_model_provider = "" # 可选: "openai", "google", "anthropic"
advan_model_endpoint = "" # 可选: 指向 [llm_endpoints.<name>]
advan_model_capabilities = ["text"] # 可选: "text", "vision"
paint_model = ""
paint_base_url = ""
video_model = "alibaba/happyhorse-1.0"
video_base_url = "https://zenmux.ai/api/vertex-ai"
basic_model_use_responses_api = true
advan_model_use_responses_api = true

[llm_endpoints.openrouter]
provider = "openai"
base_url = ""
api_key = ""
capabilities = ["text"]

[llm_endpoints.anthropic_proxy]
provider = "anthropic"
base_url = ""
api_key = ""
capabilities = ["text"]

[key]
openai_api_key = ""
paint_api_key = ""
video_api_key = "" # 可选，也可通过 ZENMUX_API_KEY 环境变量提供
google_api_key = ""
anthropic_api_key = ""
anthropic_base_url = ""
deepseek_api_key = ""
deepseek_api_base = ""
nasa_api_key = "DEMO_KEY"
github_pat = ""

[function]
agent_module_enabled = true
paint_module_enabled = true
video_module_enabled = true

agent_capability = "medium" # "low","medium","high","xhigh"
agent_whitelist_mode = false
agent_whitelist_person_list = []
agent_whitelist_group_list = []
agent_blacklist_person_list = []
agent_blacklist_group_list = []
agent_auto_reply_whitelist_mode = false
agent_auto_reply_whitelist_group_list = []
agent_auto_reply_blacklist_group_list = []

paint_whitelist_mode = false
paint_whitelist_person_list = []
paint_whitelist_group_list = []
paint_blacklist_person_list = []
paint_blacklist_group_list = []
paint_rate_limit_max_requests = 3
paint_rate_limit_window_seconds = 600
video_rate_limit_max_requests = 1
video_rate_limit_window_seconds = 900
video_poll_interval_seconds = 15
video_poll_timeout_seconds = 900
agent_llm_timeout_seconds = 900 # deep_agent 单次模型请求超时，单位秒
agent_job_timeout_seconds = 3600 # deep_agent 整次任务超时，单位秒

[message]
test_group_id = []
announce_group_id = []
apod_group_id = []
earth_now_group_id = []
news_summary_group_id = []
earthquake_group_id = []
nrc_merchant_group_id = []

[database]
query_message_numbers = 100


[debug]
agent_debug_mode = false

[dashboard]
password = "admin"
jwt_secret = "change-this-to-a-random-string-in-production"
jwt_expire_hours = 24

[content_check]
# 需要先执行 `uv sync --extra content-check`；Docker 使用 runtime-content-check 构建目标。
enabled = false
